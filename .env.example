# Authentication - NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Zitadel OIDC Configuration (using PKCE - no client secret needed)
AUTH_ZITADEL_ISSUER=https://your-zitadel-instance.zitadel.cloud
AUTH_ZITADEL_CLIENT_ID=

# NextAuth URL (automatically set in Vercel, needed for local dev)
NEXTAUTH_URL=http://localhost:3000

# Database - Neon PostgreSQL (Phase 2+)
# Get connection string from Neon console or Vercel Storage
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# ===========================================
# QuickBooks Online API
# ===========================================

# Environment: 'sandbox' for development, 'production' for live data
QBO_ENVIRONMENT=sandbox

# QBO OAuth Credentials (from Intuit Developer Portal)
# Use sandbox credentials for development
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback

# Encryption key for QBO tokens (generate with: openssl rand -base64 32)
# IMPORTANT: Use a different key for production
QBO_ENCRYPTION_KEY=

# ===========================================
# Production QBO Settings (after Intuit approval)
# ===========================================
# For production deployment, set these in Vercel:
#
# QBO_ENVIRONMENT=production
# QBO_CLIENT_ID=<production_client_id>
# QBO_CLIENT_SECRET=<production_client_secret>
# QBO_REDIRECT_URI=https://your-domain.com/api/qbo/callback
# QBO_ENCRYPTION_KEY=<new_production_key>

# Vercel Blob Storage (Phase 3+)
BLOB_READ_WRITE_TOKEN=

# Claude Vision API (Phase 5+)
# ANTHROPIC_API_KEY=

# ===========================================
# Google Maps API (Phase 6+ - Mileage Calculation)
# ===========================================
# Required for distance calculation and address autocomplete
#
# Setup:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new API key (or use existing)
# 3. Enable these APIs for your project:
#    - Distance Matrix API
#    - Places API
#    - Directions API (for waypoint routing)
# 4. Restrict the API key to server-side usage only
#
GOOGLE_MAPS_API_KEY=
