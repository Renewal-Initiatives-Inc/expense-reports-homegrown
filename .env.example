# Authentication - NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Zitadel OIDC Configuration (using PKCE - no client secret needed)
AUTH_ZITADEL_ISSUER=https://your-zitadel-instance.zitadel.cloud
AUTH_ZITADEL_CLIENT_ID=

# NextAuth URL (automatically set in Vercel, needed for local dev)
NEXTAUTH_URL=http://localhost:3000

# QuickBooks Online API (Phase 2+)
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback

# Claude Vision API (Phase 5+)
# ANTHROPIC_API_KEY=

# Google Maps API (Phase 4+)
# GOOGLE_MAPS_API_KEY=
