# Authentication - NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Zitadel OIDC Configuration (using PKCE - no client secret needed)
AUTH_ZITADEL_ISSUER=https://your-zitadel-instance.zitadel.cloud
AUTH_ZITADEL_CLIENT_ID=

# NextAuth URL (automatically set in Vercel, needed for local dev)
NEXTAUTH_URL=http://localhost:3000

# Database - Neon PostgreSQL (Phase 2+)
# Get connection string from Neon console or Vercel Storage
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# ===========================================
# Financial System Integration
# ===========================================
# Connection to financial-system Neon DB using expense_reports_role
# Permissions: SELECT on funds, accounts; INSERT+SELECT on staging_records
FINANCIAL_SYSTEM_DATABASE_URL=postgres://expense_reports_role:<password>@<host>/neondb?sslmode=require

# Vercel Blob Storage (Phase 3+)
BLOB_READ_WRITE_TOKEN=

# Claude Vision API (Phase 4+)
# Used for AI-powered receipt data extraction
ANTHROPIC_API_KEY=

# ===========================================
# Google Maps API (Phase 6+ - Mileage Calculation)
# ===========================================
# Required for distance calculation and address autocomplete
#
# Setup:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new API key (or use existing)
# 3. Enable these APIs for your project:
#    - Distance Matrix API
#    - Places API
#    - Directions API (for waypoint routing)
# 4. Restrict the API key to server-side usage only
#
GOOGLE_MAPS_API_KEY=

# ===========================================
# AWS Email Pipeline (Phase 13+ - Email Receipts)
# ===========================================
# Required for receiving forwarded receipt emails via AWS SES.
#
# Setup: See docs/aws-email-setup.md for step-by-step instructions.
#
# IAM user needs: s3:GetObject on email bucket, ses:SendEmail for auto-replies
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Must match the SES receiving region (us-east-1, us-west-2, or eu-west-1)
AWS_SES_REGION=us-east-1
# S3 bucket where SES stores raw emails
AWS_S3_EMAIL_BUCKET=
# From address for auto-reply emails (Phase 15)
AWS_SES_FROM_ADDRESS=noreply@expenses.renewalinitiatives.org
